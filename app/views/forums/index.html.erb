<%= render Forums::BiasMeterComponent.new(value: @bias_value, posts_analyzed: @posts_analyzed, history: @bias_history) %>

<% @categories.each do |category| %>
  <%= render Forums::CategoryPanelComponent.new(name: category[:name], forums: category[:forums]) %>
<% end %>

<%= render Forums::LatestPostsComponent.new(posts: @latest_posts) %>

<div class="flex gap-4.5 flex-wrap">
  <%= render Forums::WhosOnlineComponent.new(users: @online_users, summary: @online_summary) %>
  <%= render Forums::StatsPanelComponent.new(threads: @stats[:threads], posts: @stats[:posts], members: @stats[:members], newest_member: @stats[:newest_member]) %>
</div>
