<%= render Ui::BreadcrumbComponent.new(items: @breadcrumb) %>

<%= render Forums::ForumHeaderComponent.new(title: @forum[:title], description: @forum[:description], subforums: @forum[:subforums]) %>

<%= render Forums::ThreadListComponent.new(threads: @threads, thread_path: ->(thread) {
  thread[:title] == "Midterm predictions thread" ? forum_thread_path(forum_id: params[:id], id: "midterm-predictions-thread") : "#"
}) %>

<%= render Ui::PaginationComponent.new(pages: @pages) %>
