<%= render Ui::BreadcrumbComponent.new(items: [ { label: "Quorum", href: root_path }, { label: "Political Affiliations", current: true } ]) %>

<div class="flex justify-between items-start gap-4 flex-wrap mb-2">
  <div>
    <div class="text-xl font-bold">Political Affiliations</div>
    <div class="text-xs text-muted mt-1 max-w-[640px]">Member-created factions. Join one, or start your own. These groups are run entirely by members and don't reflect any official position of the forum staff.</div>
  </div>
</div>

<% if current_user %>
  <details class="border border-line rounded-[4px] bg-row shadow-sm my-3.5">
    <summary class="cursor-pointer bg-linear-to-b from-panel-from to-panel-to px-3.5 py-2 text-panel-heading font-bold text-[13px] list-none">+ Propose New Affiliation</summary>
    <%= form_with model: Faction.new, url: affiliations_path, class: "p-3.5 flex flex-col gap-2.5" do |f| %>
      <div>
        <div class="text-[11px] text-muted mb-1 font-bold">NAME</div>
        <%= f.text_field :name, placeholder: "e.g. Reform Bloc", class: "w-full box-border p-2 border border-line rounded-[3px] [font-family:inherit] text-[13px]" %>
      </div>
      <div>
        <div class="text-[11px] text-muted mb-1 font-bold">DESCRIPTION</div>
        <%= f.text_area :description, placeholder: "What does this group stand for?", class: "w-full h-[60px] box-border p-2 border border-line rounded-[3px] [font-family:inherit] text-[13px] resize-y" %>
      </div>
      <div class="flex justify-end">
        <%= f.submit "Create Affiliation", class: "py-1.5 px-4 border border-register-line rounded-[3px] bg-register text-white text-xs font-bold cursor-pointer [font-family:inherit] hover:opacity-90" %>
      </div>
    <% end %>
  </details>
<% else %>
  <div class="text-xs text-muted my-3.5"><%= link_to "Log in", new_user_session_path, class: "text-link hover:underline" %> to propose a new affiliation.</div>
<% end %>

<div class="flex gap-4 flex-wrap my-4">
  <%= render Affiliations::LeaderboardCardComponent.new(label: "This Week — Most Active", entry: @leaderboard[:most_active]) %>
  <%= render Affiliations::LeaderboardCardComponent.new(label: "This Week — Most Balanced", entry: @leaderboard[:most_balanced]) %>
</div>

<div class="flex flex-wrap gap-4">
  <% @factions.each do |faction| %>
    <%= render Affiliations::FactionCardComponent.new(faction: faction, current_user: current_user) %>
  <% end %>
</div>
