<%#
  A curated emoji picker for Lexxy editors. Uses Lexxy's own "prompts"
  feature (trigger=":" like Slack/Discord/GitHub) with insert-editable-text
  so selected emoji are inserted as plain characters, not Action Text
  attachments — Lexxy's own docs call this out as the intended use case
  for emoji specifically. Items are inline (no server round trip needed
  for a small static list). The same Emoji::LIST backs signature markdown
  shortcode rendering.
%>
<lexxy-prompt trigger=":" insert-editable-text empty-results="No emoji found">
  <% Emoji::LIST.each do |name, emoji| %>
    <lexxy-prompt-item search="<%= name %>">
      <template type="menu"><%= emoji %> <%= name %></template>
      <template type="editor"><%= emoji %></template>
    </lexxy-prompt-item>
  <% end %>
</lexxy-prompt>
