<%= render Ui::BreadcrumbComponent.new(items: [
  { label: "Quorum", href: root_path },
  { label: "#{@profile[:name]}'s Profile", current: true }
]) %>

<%= render Users::ProfileHeaderComponent.new(profile: @profile) %>

<% if @profile[:is_own_profile] %>
  <div class="mb-4.5 -mt-2.5">
    <%= link_to "Edit Profile", edit_profile_path, class: "text-xs text-link hover:underline" %>
  </div>
<% end %>

<% if @signature_pending_review %>
  <div class="mb-4.5 px-3 py-2 border border-dashed border-[#b8933a] rounded-[4px] bg-[#fbf3de] text-[11px] text-[#6b5220]">
    Your signature contains images and is awaiting moderator approval — it isn't shown publicly yet.
  </div>
<% end %>

<% if @notifications %>
  <%= render Ui::PanelComponent.new(title: "Notifications") do %>
    <% if @notifications.empty? %>
      <div class="px-3.5 py-3 text-xs text-muted">No notifications yet.</div>
    <% else %>
      <% @notifications.each do |notification| %>
        <div class="px-3.5 py-2.5 border-b border-line text-xs flex justify-between items-center gap-2.5 <%= "bg-row-alt" if notification.unread? %>">
          <%= link_to notification.message, notification.url, class: "text-link hover:underline" %>
          <span class="text-[10px] text-muted shrink-0"><%= notification.created_at.strftime("%b %-d, %Y") %></span>
        </div>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<div class="flex gap-4.5 flex-wrap mt-4.5">
  <div class="flex-1 min-w-[220px] flex flex-col gap-4.5 h-fit">
    <% if @affiliation %>
      <%= render Users::AffiliationPanelComponent.new(affiliation: @affiliation) %>
    <% end %>
    <%= render Users::StatsPanelComponent.new(stats: @stats) %>
  </div>

  <div class="flex-[2.4] min-w-[320px] flex flex-col gap-4.5">
    <%= render Users::AboutMeComponent.new(bio: @about_me, signature: @signature) %>
    <%= render Users::RecentPostsComponent.new(posts: @recent_posts) %>
  </div>
</div>
