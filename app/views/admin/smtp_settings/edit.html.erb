<%= render Ui::PanelComponent.new(title: "Email (SMTP)") do %>
  <div class="p-4">
    <%= form_with model: @smtp_setting, url: admin_smtp_settings_path, method: :patch, local: true do |f| %>
      <div class="grid gap-3.5" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
        <div>
          <label class="block text-[11px] font-bold text-muted mb-1.5" for="smtp_setting_address">SMTP HOST</label>
          <%= f.text_field :address, placeholder: "smtp.example.com", class: "w-full px-2.5 py-1.5 border border-line rounded-[3px] text-xs" %>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-muted mb-1.5" for="smtp_setting_port">PORT</label>
          <%= f.number_field :port, class: "w-full px-2.5 py-1.5 border border-line rounded-[3px] text-xs" %>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-muted mb-1.5" for="smtp_setting_domain">HELO DOMAIN</label>
          <%= f.text_field :domain, placeholder: "example.com", class: "w-full px-2.5 py-1.5 border border-line rounded-[3px] text-xs" %>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-muted mb-1.5" for="smtp_setting_authentication">AUTHENTICATION</label>
          <%= f.select :authentication, SmtpSetting::AUTHENTICATION_METHODS.map { |m| [ m.titleize, m ] }, {}, class: "w-full px-2.5 py-1.5 border border-line rounded-[3px] text-xs" %>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-muted mb-1.5" for="smtp_setting_user_name">USERNAME</label>
          <%= f.text_field :user_name, class: "w-full px-2.5 py-1.5 border border-line rounded-[3px] text-xs" %>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-muted mb-1.5" for="smtp_setting_password">PASSWORD</label>
          <%= f.password_field :password, placeholder: @smtp_setting.password.present? ? "•••••••••••••••• (unchanged)" : "", class: "w-full px-2.5 py-1.5 border border-line rounded-[3px] text-xs" %>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-muted mb-1.5" for="smtp_setting_from_address">FROM ADDRESS</label>
          <%= f.text_field :from_address, placeholder: "no-reply@example.com", class: "w-full px-2.5 py-1.5 border border-line rounded-[3px] text-xs" %>
        </div>
        <div class="flex items-end">
          <label class="flex items-center gap-1.5 text-[11px] text-muted"><%= f.check_box :enable_starttls_auto %> Enable STARTTLS auto-detect</label>
        </div>
      </div>

      <%= f.submit "Save", class: "px-4.5 py-2 border border-register-line rounded-[3px] bg-register text-white text-xs font-bold cursor-pointer [font-family:inherit] hover:opacity-90 mt-3.5" %>
    <% end %>
    <%= button_to "Send Test Email", test_admin_smtp_settings_path, method: :post, class: "px-4.5 py-2 border border-line rounded-[3px] bg-row text-ink text-xs font-bold cursor-pointer [font-family:inherit] hover:bg-row-alt mt-2.5" %>
  </div>
<% end %>
