<div class="border border-line rounded-[4px] bg-row shadow-sm">
  <div class="bg-linear-to-b from-panel-from to-panel-to px-3.5 py-2 text-panel-heading font-bold text-[13px]">Post a Reply</div>
  <div class="p-3.5">
    <div class="flex gap-1 mb-2">
      <span class="w-6.5 h-5.5 border border-line rounded-[3px] flex items-center justify-center font-bold text-[11px] bg-row-alt">B</span>
      <span class="w-6.5 h-5.5 border border-line rounded-[3px] flex items-center justify-center italic text-[11px] bg-row-alt">I</span>
      <span class="w-6.5 h-5.5 border border-line rounded-[3px] flex items-center justify-center underline text-[11px] bg-row-alt">U</span>
      <span class="w-6.5 h-5.5 border border-line rounded-[3px] flex items-center justify-center text-[11px] bg-row-alt">&#128279;</span>
      <span class="w-6.5 h-5.5 border border-line rounded-[3px] flex items-center justify-center text-[11px] bg-row-alt">&#128247;</span>
    </div>
    <textarea placeholder="Write your reply..." class="w-full h-[100px] box-border p-2 border border-line rounded-[3px] [font-family:inherit] text-[13px] resize-y"></textarea>
    <div class="flex justify-end mt-2.5">
      <button class="px-4.5 py-2 border border-register-line rounded-[3px] bg-register text-white text-xs font-bold cursor-pointer [font-family:inherit] hover:opacity-90">Post Reply</button>
    </div>
  </div>
</div>
