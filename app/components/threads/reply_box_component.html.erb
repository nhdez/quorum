<%= render Ui::PanelComponent.new(title: "Post a Reply") do %>
  <div class="p-3.5">
    <%= form_with model: ThreadReply.new, url: reply_path do |f| %>
      <div data-controller="word-count" data-word-count-max-value="<%= max_word_count %>">
        <%= f.rich_textarea :body, data: { word_count_target: "editor", action: "lexxy:change->word-count#update" } do %>
          <lexxy-prompt trigger="@" src="<%= mentions_path %>" name="mention" remote-filtering empty-results="No users found">
          </lexxy-prompt>
          <%= render "shared/emoji_prompt" %>
        <% end %>
        <div class="text-[11px] text-muted mt-1" data-word-count-target="output"></div>
      </div>
      <div class="flex justify-end mt-2.5">
        <%= f.submit "Post Reply", class: "px-4.5 py-2 border border-register-line rounded-[3px] bg-register text-white text-xs font-bold cursor-pointer [font-family:inherit] hover:opacity-90" %>
      </div>
    <% end %>
  </div>
<% end %>
