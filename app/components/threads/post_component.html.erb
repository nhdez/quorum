<div class="grid grid-cols-[180px_1fr] border-b border-line <%= "bg-[#e7f3e9]" if post[:highlighted] %>">

  <!-- LEFT: user card -->
  <div class="relative border-r border-line overflow-hidden bg-[#1b2230]">
    <div class="absolute inset-0 z-[1] pointer-events-none bg-linear-to-b from-black/32 via-black/70 to-black/90"></div>
    <div class="relative z-[2] p-4 text-center">
      <a href="#" class="text-white font-bold text-[13px] [text-shadow:0_1px_2px_rgba(0,0,0,0.5)] hover:underline"><%= post[:user] %></a>
      <div class="text-[11px] text-white/85 mt-0.5 font-bold [text-shadow:0_1px_2px_rgba(0,0,0,0.5)]"><%= post[:rank] %></div>
      <div class="w-16 h-16 rounded-full text-white flex items-center justify-center font-bold text-2xl mx-auto my-2.5 border-2 border-white/40" style="background: <%= post[:avatar_color] %>;"><%= post[:initial] %></div>

      <% if post[:affiliation_name].present? %>
        <div class="inline-block text-[10px] font-bold text-white bg-black/35 rounded-full px-2 py-0.5 mt-1" style="border: 1px solid <%= post[:affiliation_color] %>;"><%= post[:affiliation_name] %></div>
      <% end %>

      <% if post[:is_devils_advocate] %>
        <div title="Awarded when the AI bot flags a post from this user as reading against their own affiliation's typical stance." class="inline-block text-[10px] font-bold text-[#3a2c15] bg-[#f3dd9c] border border-[#c9a94a] rounded-full px-2 py-0.5 mt-1">&#127917; Devil's Advocate</div>
      <% end %>

      <div class="text-[10px] text-white/80 text-left mt-2 leading-relaxed [text-shadow:0_1px_2px_rgba(0,0,0,0.5)]">
        <div>Joined: <%= post[:joined] %></div>
        <div>Posts: <%= post[:post_count] %></div>
      </div>
    </div>
  </div>

  <!-- RIGHT: post content -->
  <div class="p-4 flex flex-col">
    <div class="flex justify-between text-[11px] text-muted border-b border-dashed border-line pb-2 mb-2.5">
      <span><%= post[:time] %></span>
      <span>Post #<%= post[:number] %></span>
    </div>

    <div class="text-[13px] flex-1 [&_p]:mb-3 [&_p:last-child]:mb-0"><%= post[:body] %></div>

    <% if post[:ai_flag_reason].present? %>
      <div class="mt-3 px-3 py-2 border border-dashed border-[#b8933a] rounded-[4px] bg-[#fbf3de] text-[11px] text-[#6b5220]">
        <b>&#129302; AI Flag:</b> <%= post[:ai_flag_reason] %>
        <div class="mt-0.5 italic opacity-85">Automated observation only — not a moderation action.</div>
      </div>
    <% end %>

    <% if post[:signature].present? %>
      <div class="mt-2.5 pt-2 border-t border-dotted border-line text-[11px] italic text-muted"><%= post[:signature] %></div>
    <% end %>

    <div class="flex gap-2 mt-3.5 justify-end">
      <button class="px-3 py-1.5 border border-line rounded-[3px] bg-row-alt text-ink text-[11px] cursor-pointer [font-family:inherit] hover:bg-line">Quote</button>
      <button class="px-3 py-1.5 border border-line rounded-[3px] bg-row-alt text-ink text-[11px] cursor-pointer [font-family:inherit] hover:bg-line">Report</button>
    </div>
  </div>
</div>
