<div class="border border-line rounded-[4px] mb-5 bg-row overflow-hidden shadow-sm">
  <div class="bg-linear-to-b from-panel-from to-panel-to px-3.5 py-2 text-panel-heading font-bold text-[13px] flex justify-between items-center">
    <span>&#9878;&#65039; Daily Political Bias Index</span>
    <span class="text-[11px] font-normal opacity-85">Auto-generated from the last 24 hours of posts</span>
  </div>
  <div class="px-6 pt-4.5 pb-3.5">
    <div class="text-[13px] mb-3">
      Today's aggregate lean: <b style="color: <%= color %>;"><%= label %></b>
      <span class="text-muted"> &mdash; based on sentiment analysis of <%= posts_analyzed %> posts across all boards.</span>
    </div>

    <div class="relative h-5.5 rounded-full border border-black/15 bg-linear-to-r from-[#2a56a8] via-[#8b8b93] to-[#b8302f]">
      <div class="absolute -top-2.5 w-0 h-0 border-x-[9px] border-x-transparent border-t-[12px] border-t-ink -translate-x-1/2" style="left: <%= value %>%;"></div>
      <div class="absolute -bottom-2.5 w-0 h-0 border-x-[9px] border-x-transparent border-b-[12px] border-b-ink -translate-x-1/2" style="left: <%= value %>%;"></div>
    </div>

    <div class="flex justify-between text-[10px] text-muted mt-1.5 font-bold tracking-wide">
      <span>STRONG LEFT</span>
      <span>LEFT</span>
      <span>CENTER</span>
      <span>RIGHT</span>
      <span>STRONG RIGHT</span>
    </div>

    <div class="text-[11px] text-muted mt-2.5 italic">Last updated: Today, 06:00 AM &middot; Methodology: automated language-model classification, not moderator opinion.</div>

    <div class="mt-4 pt-3 border-t border-dashed border-line">
      <div class="text-[10px] text-muted mb-1 font-bold uppercase tracking-wide">30-Day Trend</div>
      <svg width="100%" height="36" viewBox="0 0 300 36" preserveAspectRatio="none" class="block">
        <polyline points="<%= sparkline_points %>" fill="none" stroke="<%= color %>" stroke-width="2"></polyline>
      </svg>
    </div>
  </div>
</div>
